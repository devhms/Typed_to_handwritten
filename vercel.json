{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/generate",
      "destination": "/api/generate.py"
    },
    {
      "source": "/health",
      "destination": "/api/health.py"
    }
  ]
}
